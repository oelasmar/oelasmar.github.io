---
import { siteConfig } from "../config";
// Asumiendo que añadirás "certifications" a tu siteConfig
const hasCertifications = siteConfig.certifications && siteConfig.certifications.length > 0;
---

{
  hasCertifications && (
    <section id="certifications" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50/50">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          {/* Título de la sección */}
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Certifications
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          {/* Grid de Certificaciones: 2 columnas en pantallas medianas/grandes */}
          <div class="lg:col-span-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {siteConfig.certifications.map((cert) => (
                <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-5 hover:shadow-md transition-all duration-300 hover:-translate-y-1">
                  <div class="flex justify-between items-start mb-3">
                    <div class="flex-1">
                      <h3 class="text-lg font-bold text-gray-900 leading-tight">
                        {cert.title}
                      </h3>
                      <p
                        class="text-sm font-medium mt-1"
                        style={`color: ${siteConfig.accentColor}`}
                      >
                        {cert.issuer}
                      </p>
                    </div>
                    {/* Badge de fecha opcional */}
                    <span class="text-[10px] uppercase tracking-wider font-bold bg-gray-100 text-gray-500 px-2 py-1 rounded ml-2 whitespace-nowrap">
                      {cert.date}
                    </span>
                  </div>

                  {cert.description && (
                    <p class="text-sm text-gray-600 line-clamp-3">
                      {cert.description}
                    </p>
                  )}
                  
                  {cert.link && (
                    <a 
                      href={cert.link} 
                      target="_blank" 
                      class="inline-block mt-4 text-xs font-bold uppercase tracking-wider hover:underline"
                      style={`color: ${siteConfig.accentColor}`}
                    >
                      View Credential →
                    </a>
                  )}
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}