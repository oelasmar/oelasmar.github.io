---
import { siteConfig } from "../config";
---

<section id="contact" class="relative py-24 bg-white overflow-hidden">
  <div 
    class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"
  ></div>

  <div class="mx-auto max-w-7xl px-8 sm:px-12 md:px-24">
    <div class="flex flex-col items-center text-center">
      <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-gray-900 tracking-tight">
        Get in <span style={{ color: siteConfig.accentColor }}>Touch</span>
      </h2>
      <div
        class="w-[60px] h-[5px] mt-4 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      ></div>
      
      <p class="mt-8 text-lg md:text-xl text-gray-600 max-w-2xl">
        ¿Tienes algún proyecto en mente o simplemente quieres saludar? Mis bandejas de entrada están siempre abiertas.
      </p>

      <div class="mt-12 flex flex-wrap justify-center gap-6 md:gap-10">
        
        {siteConfig.social?.email && (
          <a
            href={`mailto:${siteConfig.social.email}`}
            class="group flex flex-col items-center gap-3 p-4 transition-all duration-300 hover:-translate-y-2"
          >
            <div class="w-16 h-16 rounded-2xl bg-gray-50 flex items-center justify-center text-gray-700 group-hover:bg-blue-50 group-hover:text-[var(--accent-color)] shadow-sm border border-gray-100 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0l-8.25 5.25l-8.25-5.25" />
              </svg>
            </div>
            <span class="text-sm font-bold text-gray-500 group-hover:text-gray-900 uppercase tracking-widest">Email</span>
          </a>
        )}

        {siteConfig.social?.linkedin && (
          <a
            href={siteConfig.social.linkedin}
            target="_blank"
            class="group flex flex-col items-center gap-3 p-4 transition-all duration-300 hover:-translate-y-2"
          >
            <div class="w-16 h-16 rounded-2xl bg-gray-50 flex items-center justify-center text-gray-700 group-hover:bg-blue-50 group-hover:text-[#0077b5] shadow-sm border border-gray-100 transition-colors">
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </div>
            <span class="text-sm font-bold text-gray-500 group-hover:text-gray-900 uppercase tracking-widest">LinkedIn</span>
          </a>
        )}

        {siteConfig.social?.github && (
          <a
            href={siteConfig.social.github}
            target="_blank"
            class="group flex flex-col items-center gap-3 p-4 transition-all duration-300 hover:-translate-y-2"
          >
            <div class="w-16 h-16 rounded-2xl bg-gray-50 flex items-center justify-center text-gray-700 group-hover:bg-gray-100 group-hover:text-black shadow-sm border border-gray-100 transition-colors">
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
            </div>
            <span class="text-sm font-bold text-gray-500 group-hover:text-gray-900 uppercase tracking-widest">GitHub</span>
          </a>
        )}

        {siteConfig.social?.twitter && (
          <a
            href={siteConfig.social.twitter}
            target="_blank"
            class="group flex flex-col items-center gap-3 p-4 transition-all duration-300 hover:-translate-y-2"
          >
            <div class="w-16 h-16 rounded-2xl bg-gray-50 flex items-center justify-center text-gray-700 group-hover:bg-blue-50 group-hover:text-black shadow-sm border border-gray-100 transition-colors">
              <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </div>
            <span class="text-sm font-bold text-gray-500 group-hover:text-gray-900 uppercase tracking-widest">Twitter</span>
          </a>
        )}

      </div>
</section>