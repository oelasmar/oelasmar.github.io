---
import { siteConfig } from "../config";

const technologies = [
  { name: "Docker", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-plain.svg" },
  { name: "Python", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg" },
  { name: "Qlik Sense", icon: "https://cdn.simpleicons.org/qlik/009848"},
];
---

<div
  id="hero"
  class="relative isolate overflow-hidden bg-white py-12 md:py-0 md:h-screen flex flex-col justify-center"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <div
    class="absolute inset-0 -z-10"
    style={`background: radial-gradient(ellipse 800px 1200px at 0% 0%, ${siteConfig.accentColor}40 0%, ${siteConfig.accentColor}25 20%, ${siteConfig.accentColor}10 40%, rgba(255, 255, 255, 0.3) 70%, rgba(255, 255, 255, 0.8) 90%, white 100%)`}
  ></div>
  
  <svg aria-hidden="true" class="absolute inset-0 -z-10 size-full stroke-gray-200 [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)]">
    <defs>
      <pattern x="50%" y={-1} id="grid-pattern" width={200} height={200} patternUnits="userSpaceOnUse">
        <path d="M.5 200V.5H200" fill="none"></path>
      </pattern>
      <pattern id="programming-symbols" x="0" y="0" width="400" height="400" patternUnits="userSpaceOnUse">
        <text x="50" y="50" fill={siteConfig.accentColor} font-family="monospace" font-size="24" transform="rotate(-15)">&lt;/&gt;</text>
        <text x="150" y="100" fill={siteConfig.accentColor} font-family="monospace" font-size="20" transform="rotate(10)">{}</text>
        <text x="250" y="80" fill={siteConfig.accentColor} font-family="monospace" font-size="18" transform="rotate(-5)">=&gt;</text>
        <text x="100" y="200" fill={siteConfig.accentColor} font-family="monospace" font-size="22" transform="rotate(15)">[]</text>
      </pattern>
    </defs>
    <rect fill="url(#programming-symbols)" width="100%" height="100%" opacity="0.2"></rect>
    <rect fill="url(#grid-pattern)" width="100%" height="100%" stroke-width={0}></rect>
  </svg>

  <div class="mx-auto max-w-7xl px-8 sm:px-12 md:px-24 w-full">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      
      <div class="order-2 md:order-1">
        <h2 class="text-xl md:text-2xl font-bold tracking-tight text-gray-700 animate-fade-in">
          Hello! 👋
        </h2>
        <h1 class="mt-4 text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-gray-800 animate-fade-in animation-delay-200">
          I'm <span style={{ color: siteConfig.accentColor }}>{siteConfig.name}</span>
        </h1>
        <p class="mt-2 text-xl md:text-2xl font-medium text-gray-600 animate-fade-in animation-delay-400">
          {siteConfig.title}
        </p>
        <p class="mt-6 text-pretty text-lg leading-relaxed text-gray-600 animate-fade-in animation-delay-400 max-w-xl">
          {siteConfig.description}
        </p>
      </div>

      <div class="order-1 md:order-2 flex justify-center animate-fade-in animation-delay-200">
        <div class="relative group">
          <div 
            class="absolute -inset-1 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000"
            style={`background-color: ${siteConfig.accentColor}`}
          ></div>
          <img 
            src="/tu-foto.jpg" 
            alt={siteConfig.name}
            class="relative w-64 h-64 md:w-80 md:h-80 object-cover rounded-2xl shadow-2xl border-4 border-white transform transition duration-500 hover:scale-[1.02]"
          />
        </div>
      </div>
    </div>

    <div class="mt-16 md:mt-24 animate-fade-in animation-delay-600">
      <h3 class="text-sm uppercase tracking-[0.2em] text-gray-500 font-bold mb-8 text-center md:text-left">
        Expertise & Tech Stack
      </h3>
      <div class="flex flex-wrap justify-center md:justify-start gap-8 md:gap-12">
        {technologies.map((tech) => (
          <div class="flex flex-col items-center group cursor-help">
            <img 
              src={tech.icon} 
              alt={tech.name} 
              class="w-10 h-10 md:w-12 md:h-12 transition-all duration-300 transform group-hover:scale-110 group-hover:drop-shadow-md" 
            />
            <span class="mt-2 text-xs font-bold text-gray-400 group-hover:text-gray-800 uppercase tracking-tighter transition-colors">
              {tech.name}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in { animation: fadeIn 0.8s ease-out forwards; opacity: 0; }
  .animation-delay-200 { animation-delay: 0.2s; }
  .animation-delay-400 { animation-delay: 0.4s; }
  .animation-delay-600 { animation-delay: 0.6s; }
</style>